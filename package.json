  "name": "backpack",
  "scripts": {
    "dev": "bun x concurrently --kill-others --names \"next,trigger\" --prefix-colors \"yellow, blue\" \"next dev --turbopack\" \"bun run trigger:dev\"",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "bun x ultracite check",
    "lint:fix": "bun x ultracite fix",
    "audit": "bun audit",
    "check": "bun run typecheck && bun run lint && bun run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:drop": "drizzle-kit drop",
    "db:pull": "drizzle-kit introspect",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "prepare": "husky",
    "doctor": "bun x react-doctor@latest",
    "trigger:dev": "bun x trigger.dev@latest dev",
    "trigger:deploy": "bun x trigger.dev@latest deploy"
  },
  "version": "0.2.0",
  "private": true,
